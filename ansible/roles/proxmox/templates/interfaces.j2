{# ansible/roles/proxmox/templates/interfaces.j2 #}
{# Proxmox network interfaces — VLAN-aware bridge design               #}
{# Rendered per node using host_vars (proxmox_nic, proxmox_mgmt_ip)   #}
{# Verify NIC name before applying: ip link show                       #}

auto lo
iface lo inet loopback

# Physical NIC — trunk member port, no IP.
# bridge-pvids 10 sets PVID=10 on this uplink port so untagged frames
# arriving from the switch trunk (native VLAN 10) are classified into
# VLAN 10 by the bridge instead of defaulting to VLAN 1.
auto {{ proxmox_nic }}
iface {{ proxmox_nic }} inet manual
    bridge-pvids 10

# vmbr0 — VLAN-aware bridge
# VMs/LXCs set their VLAN tag in the hardware config; 802.1Q tagging
# is handled transparently by the bridge.
#
# bridge-pvids 10: marks the CPU port (vmbr0) native VLAN as 10 so:
#   • Management traffic from Proxmox egresses untagged as VLAN 10
#   • VLAN 10 frames from the switch arrive untagged at the CPU port
#   • 'bridge vlan show dev vmbr0' reports: 10 PVID Egress Untagged
auto vmbr0
iface vmbr0 inet static
    address {{ proxmox_mgmt_ip }}/24
    gateway {{ proxmox_mgmt_gw }}
    bridge-ports {{ proxmox_nic }}
    bridge-stp off
    bridge-fd 0
    bridge-vlan-aware yes
    bridge-vids 2-4094
    bridge-pvids 10

{% if proxmox_role == 'primary' %}
# AMDPVE only — Ceph public network (VLAN 30)
# N1 Mini also needs this if participating in Ceph
auto vmbr0.30
iface vmbr0.30 inet static
    address {{ proxmox_ceph_pub_ip }}/24

# Ceph cluster/replication network (VLAN 31)
auto vmbr0.31
iface vmbr0.31 inet static
    address {{ proxmox_ceph_cluster_ip }}/24
{% endif %}
