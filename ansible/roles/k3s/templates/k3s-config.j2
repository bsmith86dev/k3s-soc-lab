# ansible/roles/k3s/templates/k3s-config.j2
# k3s configuration file — rendered per node based on k3s_mode variable
# Deployed to /etc/rancher/k3s/config.yaml before k3s install

{% if k3s_mode == 'server' %}
# ── Server (control plane) config ─────────────────────────────────────────
cluster-init: true
token: "{{ vault_k3s_token }}"
node-ip: "{{ ansible_host }}"
advertise-address: "{{ ansible_host }}"
tls-san:
  - "{{ ansible_host }}"
  - "k3s-cp.lab.blerdmh.local"
  - "k3s-cp"

# Disable built-in components — using MetalLB + Traefik from manifests
disable:
  - traefik
  - servicelb

# Networking
flannel-backend: host-gw
cluster-cidr: "{{ k3s_cluster_cidr }}"
service-cidr: "{{ k3s_service_cidr }}"
cluster-dns: "{{ k3s_cluster_dns }}"

# Logging
log: /var/log/k3s.log

# Kubelet extra args
kubelet-arg:
  - "max-pods=110"
  - "eviction-hard=memory.available<100Mi,nodefs.available<10%"

{% elif k3s_mode == 'agent' %}
# ── Agent (worker) config ─────────────────────────────────────────────────
server: "https://{{ k3s_server_ip }}:6443"
token: "{{ vault_k3s_token }}"
node-ip: "{{ ansible_host }}"
# Pin node-name to inventory_hostname so kubectl queries always match,
# regardless of what cloud-init set as the OS hostname.
node-name: "{{ inventory_hostname }}"

# Kubelet extra args
# Device plugins (AMD/NVIDIA) work out of the box in k8s 1.27+; the
# DevicePlugins feature gate was removed and setting it makes kubelet
# refuse to start. GPU support is enabled by deploying the vendor's
# device plugin DaemonSet, not by a kubelet flag.
kubelet-arg:
  - "max-pods=110"

{% endif %}
