; ansible/roles/gitea/templates/app.ini.j2
; Gitea configuration — managed by Ansible
; Deployed to /etc/gitea/app.ini

APP_NAME = blerdmh Lab Git
RUN_MODE = prod
RUN_USER = git

[server]
PROTOCOL         = http
HTTP_ADDR        = 0.0.0.0
HTTP_PORT        = {{ gitea_http_port }}
ROOT_URL         = http://{{ ansible_host }}:{{ gitea_http_port }}/
DOMAIN           = {{ ansible_host }}
SSH_DOMAIN       = {{ ansible_host }}
SSH_PORT         = 2222
DISABLE_SSH      = false
START_SSH_SERVER = true
LFS_START_SERVER = true
LFS_JWT_SECRET   = {{ vault_gitea_secret_key }}

[database]
DB_TYPE  = sqlite3
PATH     = /var/lib/gitea/data/gitea.db
LOG_SQL  = false

[repository]
ROOT             = /var/lib/gitea/repos
DEFAULT_PRIVATE  = private
ENABLE_PUSH_CREATE_USER = false
ENABLE_PUSH_CREATE_ORG  = false

[security]
INSTALL_LOCK        = true
SECRET_KEY          = {{ vault_gitea_secret_key }}
INTERNAL_TOKEN      = {{ vault_gitea_secret_key }}
PASSWORD_HASH_ALGO  = argon2

[service]
DISABLE_REGISTRATION              = true
REQUIRE_SIGNIN_VIEW               = true
REGISTER_EMAIL_CONFIRM            = false
ENABLE_NOTIFY_MAIL                = false
ALLOW_ONLY_EXTERNAL_REGISTRATION  = false
ENABLE_CAPTCHA                    = false
DEFAULT_KEEP_EMAIL_PRIVATE        = true
DEFAULT_ALLOW_CREATE_ORGANIZATION = false
DEFAULT_USER_IS_RESTRICTED        = false
NO_REPLY_ADDRESS                  = noreply@lab.blerdmh.local

[mailer]
ENABLED = false

[cache]
ENABLED  = true
ADAPTER  = memory
INTERVAL = 60

[session]
PROVIDER        = file
PROVIDER_CONFIG = /var/lib/gitea/data/sessions
COOKIE_SECURE   = false
SESSION_LIFE_TIME = 86400

[picture]
DISABLE_GRAVATAR        = true
ENABLE_FEDERATED_AVATAR = false

[openid]
ENABLE_OPENID_SIGNIN = false
ENABLE_OPENID_SIGNUP = false

[log]
MODE      = file
LEVEL     = Info
ROOT_PATH = /var/lib/gitea/log
ROUTER    = console

[metrics]
ENABLED = true
TOKEN   = {{ vault_gitea_secret_key }}

[indexer]
ISSUE_INDEXER_TYPE = bleve
ISSUE_INDEXER_PATH = /var/lib/gitea/indexers/issues.bleve
REPO_INDEXER_ENABLED = true
REPO_INDEXER_PATH    = /var/lib/gitea/indexers/repos.bleve

[mirror]
DEFAULT_INTERVAL = {{ gitea_mirror_interval }}
MIN_INTERVAL     = 10m
